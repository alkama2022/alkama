# Copy this file to .env (dev) or .env.production (prod) and fill in the values.
# Never commit .env or .env.production to git.

# Full URL to your Django API — no trailing slash
# Dev:  http://localhost:8000/api
# Prod: https://your-backend-domain.com/api
VITE_API_URL=http://localhost:8000/api

# WhatsApp number in international format without + or spaces
VITE_WHATSAPP_NUMBER=08039366958

# Django Djoser JWT auth endpoints (full URLs)
VITE_AUTH_LOGIN_PATH=http://localhost:8000/auth/jwt/create/
VITE_AUTH_ME_PATH=http://localhost:8000/auth/users/me/
VITE_AUTH_LOGOUT_PATH=http://localhost:8000/auth/jwt/destroy/
